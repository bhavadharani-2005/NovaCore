{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist-server",
    "rootDir": ".",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "dist", "dist-server", "app"]
}
